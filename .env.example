# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# API
EXPO_PUBLIC_API_BASE_URL=https://your-api-deployment.vercel.app

# PostHog Analytics
EXPO_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# RevenueCat (Subscriptions)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your-revenuecat-ios-key
# EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=your-revenuecat-android-key  # TODO: uncomment when Android is launched

# Sentry (Error Tracking)
EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
SENTRY_AUTH_TOKEN=sntrys_your-auth-token
