default_platform(:ios)

# ─── App Store Connect API Key ───────────────────────────────
API_KEY = app_store_connect_api_key(
  key_id: "8522GN55AR",
  issuer_id: "69a6de84-0d5e-47e3-e053-5b8c7c11a4d1",
  key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_8522GN55AR.p8"),
  in_house: false
)

# ─── Google Play Service Account Key ─────────────────────────
GOOGLE_PLAY_JSON_KEY = ENV["GOOGLE_PLAY_JSON_KEY_PATH"] || File.expand_path("~/.google-play/service-account.json")

platform :ios do
  # ─── Metadata ───────────────────────────────────────────────
  desc "Download existing metadata from App Store Connect"
  lane :download_metadata do
    deliver(
      api_key: API_KEY,
      app_identifier: "app.mordoo.oracle",
      skip_binary_upload: true,
      skip_screenshots: true,
      run_precheck_before_submit: false,
      force: true
    )
  end

  desc "Upload metadata to App Store Connect"
  lane :upload_metadata do
    deliver(
      api_key: API_KEY,
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      skip_app_version_update: false
    )
  end

  # ─── Screenshots ────────────────────────────────────────────
  desc "Upload screenshots to App Store Connect"
  lane :upload_screenshots do
    deliver(
      api_key: API_KEY,
      skip_binary_upload: true,
      skip_metadata: true,
      force: true,
      overwrite_screenshots: true
    )
  end

  # ─── Full Deliver ───────────────────────────────────────────
  desc "Upload everything (metadata + screenshots) to App Store Connect"
  lane :deliver_all do
    deliver(
      api_key: API_KEY,
      skip_binary_upload: true,
      force: true,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false
    )
  end

  # ─── Build & Submit to App Store Connect ────────────────────
  desc "Build and upload to TestFlight (no EAS needed)"
  lane :release do
    project_root = File.expand_path("..", __dir__)

    # 1. Bump build number in app.json
    app_json_path = File.join(project_root, "app.json")
    app_json = JSON.parse(File.read(app_json_path))
    current_build = app_json["expo"]["ios"]["buildNumber"].to_i
    new_build = current_build + 1
    app_json["expo"]["ios"]["buildNumber"] = new_build.to_s
    File.write(app_json_path, JSON.pretty_generate(app_json) + "\n")
    UI.success("Bumped buildNumber: #{current_build} → #{new_build}")

    version = app_json["expo"]["version"]

    # 2. Regenerate native project from Expo config
    sh("cd #{project_root} && npx expo prebuild --clean --no-install")
    sh("cd #{project_root}/ios && unset GEM_PATH GEM_HOME && /opt/homebrew/bin/pod install")

    # 3. Build signed archive
    update_code_signing_settings(
      path: File.join(project_root, "ios", "MorDoo.xcodeproj"),
      use_automatic_signing: true,
      team_id: "WYQPT8K8K3"
    )

    build_app(
      workspace: File.join(project_root, "ios", "MorDoo.xcworkspace"),
      scheme: "MorDoo",
      configuration: "Release",
      export_method: "app-store",
      output_directory: File.join(project_root, "ios", "build"),
      output_name: "MorDoo.ipa",
      clean: true,
      xcargs: "-allowProvisioningUpdates"
    )

    # 4. Upload to TestFlight
    upload_to_testflight(
      api_key: API_KEY,
      ipa: File.join(project_root, "ios", "build", "MorDoo.ipa"),
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )

    UI.success("✅ v#{version} (#{new_build}) uploaded to App Store Connect!")
  end

  # ─── Sync from ASC ─────────────────────────────────────────
  desc "Download all metadata from App Store Connect"
  lane :sync do
    require 'spaceship'
    require 'fileutils'

    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(**{
      key_id: API_KEY[:key_id],
      issuer_id: API_KEY[:issuer_id],
      key: API_KEY[:key]
    })

    app = Spaceship::ConnectAPI::App.find("ai.mordoo.app")
    UI.user_error!("App not found!") unless app

    # Get version (edit or live)
    version = app.get_edit_app_store_version || app.get_live_app_store_version
    UI.user_error!("No app version found!") unless version

    UI.message("Found version: #{version.version_string}")

    # Download version-level localizations
    localizations = version.get_app_store_version_localizations
    localizations.each do |loc|
      locale = loc.locale
      dir = File.join("metadata", locale)
      FileUtils.mkdir_p(dir)

      {
        "description.txt" => loc.description,
        "keywords.txt" => loc.keywords,
        "promotional_text.txt" => loc.promotional_text,
        "support_url.txt" => loc.support_url,
        "marketing_url.txt" => loc.marketing_url,
        "release_notes.txt" => loc.whats_new
      }.each do |filename, content|
        next if content.nil?
        File.write(File.join(dir, filename), content.to_s)
        UI.message("Saved #{locale}/#{filename}")
      end
    end

    # Download app-level info (name, subtitle, privacy URL)
    app_info = app.fetch_latest_app_info
    if app_info
      info_locs = app_info.get_app_info_localizations
      info_locs.each do |loc|
        locale = loc.locale
        dir = File.join("metadata", locale)
        FileUtils.mkdir_p(dir)

        File.write(File.join(dir, "name.txt"), loc.name.to_s)
        File.write(File.join(dir, "subtitle.txt"), loc.subtitle.to_s)
        File.write(File.join(dir, "privacy_url.txt"), loc.privacy_policy_url.to_s)
        UI.message("Saved #{locale}/name.txt, subtitle.txt, privacy_url.txt")
      end
    end

    UI.success("Metadata downloaded to fastlane/metadata/")
  end

  # ─── Build Assignment ──────────────────────────────────────
  desc "Assign latest build to the app store version"
  lane :assign_build do
    require 'spaceship'

    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(**{
      key_id: API_KEY[:key_id],
      issuer_id: API_KEY[:issuer_id],
      key: API_KEY[:key]
    })

    app = Spaceship::ConnectAPI::App.find("ai.mordoo.app")
    version = app.get_edit_app_store_version
    UI.user_error!("No editable version found!") unless version

    builds = app.get_builds(filter: {}, limit: 10)
    latest = builds.first
    UI.user_error!("No builds found!") unless latest

    UI.message("Assigning build #{latest.version} to version #{version.version_string}...")
    version.select_build(build_id: latest.id)
    UI.success("Build #{latest.version} assigned to version #{version.version_string}!")
  end

  # ─── Prepare for Submission ────────────────────────────────
  desc "Set age rating for the app"
  lane :set_age_rating do
    require 'spaceship'

    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(**{
      key_id: API_KEY[:key_id],
      issuer_id: API_KEY[:issuer_id],
      key: API_KEY[:key]
    })

    app = Spaceship::ConnectAPI::App.find("ai.mordoo.app")
    app_info = app.fetch_latest_app_info
    age_rating = app_info.fetch_age_rating_declaration

    if age_rating
      age_rating.update(attributes: {
        "alcoholTobaccoOrDrugUseOrReferences" => "NONE",
        "contests" => "NONE",
        "gamblingSimulated" => "NONE",
        "gambling" => false,
        "gunsOrOtherWeapons" => "NONE",
        "horrorOrFearThemes" => "NONE",
        "matureOrSuggestiveThemes" => "INFREQUENT_OR_MILD",
        "medicalOrTreatmentInformation" => "NONE",
        "profanityOrCrudeHumor" => "NONE",
        "sexualContentOrNudity" => "NONE",
        "sexualContentGraphicAndNudity" => "NONE",
        "violenceCartoonOrFantasy" => "NONE",
        "violenceRealistic" => "NONE",
        "violenceRealisticProlongedGraphicOrSadistic" => "NONE",
        "lootBox" => false,
        "unrestrictedWebAccess" => false,
        "ageAssurance" => false,
        "advertising" => false,
        "healthOrWellnessTopics" => false,
        "userGeneratedContent" => false,
        "messagingAndChat" => false,
        "parentalControls" => false
      })
      UI.success("Age rating updated!")
    else
      UI.user_error!("No age rating declaration found")
    end
  end
end

# ═══════════════════════════════════════════════════════════════
# ANDROID — Google Play Store (via supply)
# ═══════════════════════════════════════════════════════════════
platform :android do
  # ─── Build & Upload AAB ────────────────────────────────────
  desc "Build AAB and upload to Google Play internal track (no EAS needed)"
  lane :release do |options|
    track = options[:track] || "internal"
    project_root = File.expand_path("..", __dir__)

    # 1. Bump versionCode in app.json
    app_json_path = File.join(project_root, "app.json")
    app_json = JSON.parse(File.read(app_json_path))
    current_code = app_json["expo"]["android"]["versionCode"].to_i
    new_code = current_code + 1
    app_json["expo"]["android"]["versionCode"] = new_code
    File.write(app_json_path, JSON.pretty_generate(app_json) + "\n")
    UI.success("Bumped versionCode: #{current_code} → #{new_code}")

    version = app_json["expo"]["version"]

    # 2. Regenerate native project from Expo config
    sh("cd #{project_root} && npx expo prebuild --platform android --clean --no-install")

    # 3. Build release AAB
    gradle(
      project_dir: File.join(project_root, "android"),
      task: "bundle",
      build_type: "Release"
    )

    # 4. Upload to Google Play
    aab_path = lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH]
    supply(
      json_key: GOOGLE_PLAY_JSON_KEY,
      package_name: "ai.mordoo.app",
      track: track,
      release_status: "draft",
      aab: aab_path,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      metadata_path: "fastlane/metadata/android"
    )

    UI.success("✅ v#{version} (#{new_code}) uploaded to Google Play (#{track})!")
  end

  # ─── Metadata ───────────────────────────────────────────────
  desc "Upload metadata to Google Play"
  lane :upload_metadata do
    supply(
      json_key: GOOGLE_PLAY_JSON_KEY,
      package_name: "ai.mordoo.app",
      track: "internal",
      release_status: "draft",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true,
      metadata_path: "fastlane/metadata/android"
    )
  end

  # ─── Screenshots ────────────────────────────────────────────
  desc "Upload screenshots to Google Play"
  lane :upload_screenshots do
    supply(
      json_key: GOOGLE_PLAY_JSON_KEY,
      package_name: "ai.mordoo.app",
      track: "internal",
      release_status: "draft",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      metadata_path: "fastlane/metadata/android"
    )
  end

  # ─── Upload AAB ─────────────────────────────────────────────
  desc "Upload AAB to Google Play internal track"
  lane :upload_build do |options|
    track = options[:track] || "internal"
    aab_path = options[:aab] || lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH]

    supply(
      json_key: GOOGLE_PLAY_JSON_KEY,
      package_name: "ai.mordoo.app",
      track: track,
      release_status: "draft",
      aab: aab_path,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      metadata_path: "fastlane/metadata/android"
    )
  end

  # ─── Promote Track ─────────────────────────────────────────
  desc "Promote a release from one track to another"
  lane :promote do |options|
    from = options[:from] || "internal"
    to = options[:to] || "production"

    supply(
      json_key: GOOGLE_PLAY_JSON_KEY,
      package_name: "ai.mordoo.app",
      track: from,
      track_promote_to: to,
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  # ─── Full Upload ────────────────────────────────────────────
  desc "Upload everything (metadata + screenshots) to Google Play"
  lane :deliver_all do
    supply(
      json_key: GOOGLE_PLAY_JSON_KEY,
      package_name: "ai.mordoo.app",
      track: "internal",
      release_status: "draft",
      skip_upload_apk: true,
      skip_upload_aab: true,
      metadata_path: "fastlane/metadata/android"
    )
  end
end
