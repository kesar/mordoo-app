# ===========================================
# .easignore — replaces .gitignore for EAS Build
# Keep mobile build uploads small
# ===========================================

# --- Inherited from .gitignore ---

node_modules/
.expo/
dist/
web-build/
.next/
expo-env.d.ts
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
.metro-health-check*
npm-debug.*
yarn-debug.*
yarn-error.*
.DS_Store
*.pem
.env*.local
*.tsbuildinfo
.vercel

# --- Additional exclusions for smaller builds ---

# Git history (not needed for build)
.git/

# iOS (EAS runs pod install and generates these)
ios/Pods/
ios/build/
ios/.xcode.env.local

# Backend API (not needed for mobile build)
api/

# Documentation & specs
docs/
*.md

# Database migrations
sql/

# Supabase config
supabase/

# Fastlane (not used during EAS build)
fastlane/

# Test files
vitest.config.ts
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# Dev tooling
CLAUDE.md
skills-lock.json
.claude/
.agents/
.superpowers/
.mcp.json
.env.example

# Nanobanana output (dev/design artifacts)
nanobanana-output/

# Screenshots (App Store assets, not needed for build)
screenshots/

# Vercel config
vercel.json

# Android build cache
android/.gradle/
android/build/
android/app/build/
