{
  "expo": {
    "name": "Mor Doo",
    "slug": "mordoo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "mordoo",
    "runtimeVersion": "1.1.0",
    "updates": {
      "url": "https://u.expo.dev/969fe2eb-8da0-4af0-be98-df44a79690a8"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.mordoo.oracle",
      "buildNumber": "3",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.mordoo.oracle",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a14",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "versionCode": 8,
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0a0a14"
      },
      "permissions": [
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "blockedPermissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-localization",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-sensors",
        {
          "motionPermission": "Allow $(PRODUCT_NAME) to detect shake gestures for Siam Si wisdom stick drawing"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#c9a84c"
        }
      ],
      "expo-sharing",
      "expo-splash-screen",
      [
        "@sentry/react-native",
        {
          "organization": "mordoo",
          "project": "react-native"
        }
      ],
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "DailyPulseWidget",
              "displayName": "Daily Pulse",
              "description": "Your daily insight at a glance",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            },
            {
              "name": "SiamSiWidget",
              "displayName": "Siam Si",
              "description": "Today's wisdom stick",
              "supportedFamilies": [
                "systemSmall",
                "accessoryRectangular"
              ]
            }
          ]
        }
      ],
      "@config-plugins/react-native-siri-shortcut"
    ],
    "extra": {
      "eas": {
        "projectId": "969fe2eb-8da0-4af0-be98-df44a79690a8",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "app.mordoo.oracle.ExpoWidgetsTarget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.app.mordoo.oracle"
                    ]
                  }
                }
              ]
            }
          }
        }
      },
      "router": {}
    },
    "owner": "kesarito"
  }
}
